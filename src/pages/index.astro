---
import Layout from "@layouts/Layout.astro";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import '../styles/global.css';

---

<Layout title="Mitosisphere: Multiplying Success, One Division at a Time">
  <style>
    :root {
      --color-logo-purple: #9A50D8;
      --color-logo-blue: #3FB8D3;
      --color-logo-text: #6A6AD4;

      --color-bg: #111827;
      --color-card-bg: #1F2937;

      --color-heading: #F9FAFB;
      --color-body: #9CA3AF;
      --color-subtle-text: #6B7280;

      --color-border: #374151;
      --color-accent-border: #4B5563;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--color-bg);
      color: var(--color-body);
      line-height: 1.7;
    }

    h1, h2, h3, h4, h5, h6 {
      color: var(--color-heading);
      font-weight: 700;
    }

    .hero-button {
      background-color: var(--color-logo-text);
      color: white;
      box-shadow: 0 4px 14px 0 rgba(106, 106, 212, 0.35);
      transition: all 0.3s ease;
    }
    .hero-button:hover {
      transform: translateY(-2px);
      background-color: #5555C3;
      box-shadow: 0 6px 20px 0 rgba(106, 106, 212, 0.45);
    }

    .hero-secondary-button {
      background-color: transparent;
      color: var(--color-logo-text);
      border: 1px solid var(--color-border);
      transition: all 0.3s ease;
    }
    .hero-secondary-button:hover {
      background-color: var(--color-card-bg);
      border-color: var(--color-logo-text);
      transform: translateY(-2px);
    }

    .initiative-card {
      background-color: var(--color-card-bg);
      border: 1px solid var(--color-border);
      border-radius: 0.75rem;
      transition: all 0.3s ease;
    }
    .initiative-card:hover {
      transform: translateY(-5px);
      border-color: var(--color-accent-border);
      box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
    }

    .join-team-section {
      background-color: #1E1B4B;
    }
    .join-team-section h2,
    .join-team-section p {
      color: white;
    }
    .join-team-section .link-primary {
      background-color: white;
      color: #1E1B4B;
      font-weight: 700;
      box-shadow: 0 4px 14px 0 rgba(0,0,0,0.2);
    }
    .join-team-section .link-primary:hover {
       background-color: #E0E7FF;
    }

    footer {
      background-color: var(--color-card-bg);
      border-top: 1px solid var(--color-border);
      color: var(--color-subtle-text);
    }
    footer a {
      color: var(--color-body);
      text-decoration: none;
    }
    footer a:hover {
      color: var(--color-logo-text);
      text-decoration: underline;
    }

  </style>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-MTGS0M0Q0Q"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-MTGS0M0Q0Q');
  </script>

  <div style="background-color: var(--color-bg);">
    <Container class="text-center pt-16 pb-16 md:pt-24 md:pb-24">
      <img src="/logo.png" alt="Mitosisphere Logo" class="mx-auto w-40 h-40 md:w-52 md:h-52 mb-8" />
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-tight text-gray-50">
        Empowering the Next Generation of <span style=`color: ${'var(--color-logo-text)'}`>Scholars</span>.
      </h1>
      <p class="text-lg md:text-xl max-w-3xl mx-auto text-gray-400 mt-6">
        Mitosisphere provides expert-designed resources for advanced biology.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <Link
          href="/initiatives"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg shadow-sm hero-button"
        >
          Explore Resources
        </Link>
        <Link
          href="/competitions"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg shadow-sm hero-secondary-button"
        >
          View Competitions
        </Link>
      </div>
    </Container>
  </div>

  <main>
    <section class="py-16 md:py-24 border-y border-gray-700" style="background-color: var(--color-card-bg);">
      <Container>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 text-center max-w-4xl mx-auto">
          <div>
            <p class="text-5xl font-extrabold" style=`color: ${'var(--color-logo-blue)'}`>1500+</p>
            <p class="text-gray-300 mt-3 text-lg">Exam Competitors from 19 Countries</p>
          </div>
          <div>
            <p class="text-5xl font-extrabold" style=`color: ${'var(--color-logo-purple)'}`>600+</p>
            <p class="text-gray-300 mt-3 text-lg">Active Discord Community Members</p>
          </div>
        </div>
      </Container>
    </section>

    <section class="py-16 md:py-24" style="background-color: var(--color-bg);">
      <Container>
        <Sectionhead>
          <Fragment slot="title">Our Initiatives:</Fragment>
          <Fragment slot="desc">Key resources to power your biology journey.</Fragment>
        </Sectionhead>
        <div class="grid md:grid-cols-3 gap-8 mt-12">
          <div class="initiative-card p-8 flex flex-col">
            <Icon name="uil:dna" class="w-10 h-10 mb-5" style=`color: ${'var(--color-logo-blue)'}` />
            <h3 class="text-xl font-bold mb-3 text-gray-100">Exams</h3>
            <p class="leading-relaxed text-gray-400 flex-grow">
              We host our signature USABO-style mock exams each year, providing realistic practice.
            </p>
            <a href="/rules.pdf" target="_blank" rel="noopener" class="mt-5 self-start inline-flex items-center px-4 py-1.5 text-sm font-medium rounded-md border border-gray-600 text-gray-400 hover:border-gray-400 hover:text-gray-200 transition-colors duration-200">
              View Rules
            </a>
          </div>
          <div class="initiative-card p-8 flex flex-col">
            <Icon name="uil:brain" class="w-10 h-10 mb-5" style=`color: ${'var(--color-logo-purple)'}` />
            <h3 class="text-xl font-bold mb-3 text-gray-100">Lamnhaj's Guide to USABO</h3>
            <p class="leading-relaxed text-gray-400 flex-grow">
              Everything you need to know to effectively study for and succeed on the USABO exams.
            </p>
            <a href="https://guide.mitosisphere.org" target="_blank" rel="noopener" class="mt-5 self-start inline-flex items-center px-4 py-1.5 text-sm font-medium rounded-md border border-gray-600 text-gray-400 hover:border-gray-400 hover:text-gray-200 transition-colors duration-200">
              Open Textbook
            </a>
          </div>
          <div class="initiative-card p-8 flex flex-col">
            <Icon name="uil:bolt" class="w-10 h-10 mb-5" style="color: #EAB308;" />
            <h3 class="text-xl font-bold mb-3 text-gray-100">BioBlitz</h3>
            <p class="leading-relaxed text-gray-400 flex-grow">
              Our interactive biology practice platform helps sharpen your USABO and medicine skills in a competitive format.
            </p>
            <a href="https://bioblitz.net" target="_blank" rel="noopener" class="mt-5 self-start inline-flex items-center px-4 py-1.5 text-sm font-medium rounded-md border border-gray-600 text-gray-400 hover:border-gray-400 hover:text-gray-200 transition-colors duration-200">
              Open BioBlitz
            </a>
          </div>
        </div>
      </Container>
    </section>

    <section class="join-team-section py-16 md:py-24">
      <Container class="text-center max-w-4xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight">Join Our Team</h2>
        <p class="text-lg md:text-xl mt-6 opacity-90">
          Interested in our mission? Apply today. We are especially looking to expand our outreach team!
        </p>
        <div class="mt-10 flex flex-col md:flex-row gap-4 justify-center">
            <Link
              href="https://forms.gle/jePabrYs13KvFSqt9"
              target="_blank"
              class:list={["link-primary inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg shadow-sm"]}
              rel="noopener"
            >
              <Icon name="uil:file-alt" class="w-5 h-5 mr-2" />
              Staff Application
            </Link>
            <Link
              href="https://discord.gg/Sq3nTXyS6D"
              target="_blank"
              class:list={["link-primary inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg shadow-sm !bg-white/10 !text-white hover:!bg-white/20"]}
              rel="noopener"
            >
              <Icon name="simple-icons:discord" class="w-5 h-5 mr-2" />
              Join Our Discord
            </Link>
          </div>
      </Container>
    </section>
  </main>

  <footer class="py-8">
    <p class="text-sm text-center">
      &copy; {new Date().getFullYear()} Mitosisphere. All Rights Reserved. &bull;
      <a href="/contact">Contact Us</a>
    </p>
  </footer>
</Layout>
